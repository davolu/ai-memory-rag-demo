# ─────────────────────────────────────────────────────────────
# AI Memory & Knowledge Retrieval — environment variables
# Copy this file to .env.local for local dev. NEVER commit real
# secrets. .env.local is git-ignored.
# ─────────────────────────────────────────────────────────────

# OpenAI — used for embeddings (text-embedding-3-small) and answers (gpt-4o-mini)
OPENAI_API_KEY=sk-...

# Postgres connection string (must have the pgvector extension available).
# Vercel Postgres / Neon give you a string like:
#   postgres://user:password@host/dbname?sslmode=require
# Either DATABASE_URL or POSTGRES_URL is read (DATABASE_URL takes priority).
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require
# POSTGRES_URL=postgres://user:password@host/dbname?sslmode=require

# NextAuth — session encryption secret. Generate one with:  openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-string

# The canonical URL of the deployed app (http://localhost:3000 for local dev)
NEXTAUTH_URL=http://localhost:3000
